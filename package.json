    "@tanstack/react-query": "^5.74.4",
    "@types/qrcode": "^1.5.6",
    "@zxing/browser": "^0.2.0",
    "autoprefixer": "^10.5.0",
    "framer-motion": "^12.6.3",
    "i18next": "^24.2.3",
